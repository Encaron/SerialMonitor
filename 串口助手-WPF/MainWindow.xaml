<Window x:Class="串口助手.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="串口助手 WPF"
        Width="920" Height="560"
        MinWidth="720" MinHeight="500"
        FontFamily="Microsoft YaHei"
        Closing="MainWindow_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontSize="12"
        Icon="icon.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ===== 调色板 ===== -->
        <SolidColorBrush x:Key="WindowBgBrush"      Color="#F0F0F0" />
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush"     Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#555555" />
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#999999" />
        <SolidColorBrush x:Key="PrimaryBrush"        Color="#0078D4" />
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#106EBE" />
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#005A9E" />
        <SolidColorBrush x:Key="SecondaryBrush"      Color="#888888" />
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#666666" />
        <SolidColorBrush x:Key="SuccessBrush"        Color="#10B981" />
        <SolidColorBrush x:Key="SuccessHoverBrush"   Color="#059669" />
        <SolidColorBrush x:Key="StatusBarBgBrush"    Color="#E6E6E6" />
        <SolidColorBrush x:Key="SeparatorBrush"      Color="#EEEEEE" />
        <SolidColorBrush x:Key="InputBorderBrush"    Color="#D0D0D0" />

        <!-- ===== 日志彩色 ===== -->
        <SolidColorBrush x:Key="LogSystemBrush"  Color="#999999" />
        <SolidColorBrush x:Key="LogSentBrush"    Color="#0078D4" />
        <SolidColorBrush x:Key="LogReceivedBrush" Color="#2D2D2D" />

        <!-- 补充色值：消除硬编码 -->
        <SolidColorBrush x:Key="TextSubtleBrush"           Color="#BBBBBB" />
        <SolidColorBrush x:Key="TextFaintBrush"            Color="#CCCCCC" />
        <SolidColorBrush x:Key="SecondaryHoverBgBrush"     Color="#F5F5F5" />
        <SolidColorBrush x:Key="ButtonDisabledBgBrush"     Color="#E8E8E8" />
        <SolidColorBrush x:Key="ReceiveAreaBgBrush"        Color="#FAFAFA" />
        <SolidColorBrush x:Key="StatusDotIdleBrush"        Color="#CCCCCC" />

        <!-- ===== 卡片样式 ===== -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="6" />
            <Setter Property="Padding"         Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Opacity="0.10" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 卡片标题 ===== -->
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="13" />
            <Setter Property="FontWeight"     Value="SemiBold" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin"          Value="0,0,0,12" />
        </Style>

        <!-- ===== 表单标签 ===== -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="12" />
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== CheckBox → Toggle Switch（滑动开关）===== -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize"       Value="11" />
            <Setter Property="Foreground"     Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin"         Value="0,4,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 滑轨 + 圆钮（Canvas 定位）-->
                            <Canvas Width="40" Height="22"
                                    ClipToBounds="True">
                                <Border x:Name="SwitchTrack"
                                        Width="40" Height="22"
                                        CornerRadius="11"
                                        Background="{DynamicResource InputBorderBrush}"
                                        SnapsToDevicePixels="True" />
                                <Ellipse x:Name="Knob"
                                         Width="18" Height="18"
                                         Fill="White"
                                         Canvas.Left="2" Canvas.Top="2" />
                            </Canvas>

                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="Knob" Property="Canvas.Left" Value="20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 主要按钮 ===== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height"        Value="32" />
            <Setter Property="MinWidth"      Value="72" />
            <Setter Property="Padding"       Value="16,0" />
            <Setter Property="FontSize"      Value="12" />
            <Setter Property="FontWeight"    Value="Normal" />
            <Setter Property="Foreground"    Value="White" />
            <Setter Property="Background"    Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush"   Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"        Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource PrimaryPressedBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource ButtonDisabledBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 次要按钮 ===== -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height"        Value="32" />
            <Setter Property="MinWidth"      Value="64" />
            <Setter Property="Padding"       Value="14,0" />
            <Setter Property="FontSize"      Value="12" />
            <Setter Property="Foreground"    Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background"    Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush"   Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"        Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource SecondaryHoverBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox 扁平样式（含暗色下拉列表） ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Height"          Value="28" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background"      Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="6,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Grid>
                                                <ContentPresenter HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Margin="6,0,20,0" />
                                                <TextBlock Text="▾" FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,20,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox"
                                     HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Center"
                                     Margin="8,0,20,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     FontSize="{TemplateBinding FontSize}"
                                     FontFamily="{TemplateBinding FontFamily}"
                                     CaretBrush="{TemplateBinding Foreground}"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource CardBgBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,1,0,0"
                                            SnapsToDevicePixels="True">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="False">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 暗色 ContextMenu / MenuItem ===== -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding"         Value="2" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding"    Value="8,4" />
        </Style>

        <!-- ===== ScrollViewer 透明底 ===== -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ===== ListBox 只读日志样式（无选中高亮）===== -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 快捷发送 Chip 按钮 ===== -->
        <Style x:Key="QuickSendChipStyle" TargetType="Button">
            <Setter Property="Height"        Value="24" />
            <Setter Property="FontSize"      Value="11" />
            <Setter Property="Padding"       Value="8,0" />
            <Setter Property="Margin"        Value="0,0,4,4" />
            <Setter Property="Foreground"    Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background"    Value="{DynamicResource SecondaryHoverBgBrush}" />
            <Setter Property="BorderBrush"   Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"        Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chip"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background"  Value="{DynamicResource CardBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 发送区 TextBox ===== -->
        <Style x:Key="SendTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily"     Value="Sarasa Mono SC, Consolas, Courier New" />
            <Setter Property="FontSize"       Value="12" />
            <Setter Property="Foreground"     Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background"     Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush"    Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"        Value="6,4" />
            <Setter Property="AcceptsReturn"  Value="True" />
            <Setter Property="TextWrapping"   Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="SpellCheck.IsEnabled" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="MinHeight"      Value="68" />
            <Setter Property="MaxHeight"      Value="140" />
        </Style>
    </Window.Resources>

    <!-- ===== 主布局 ===== -->
    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== 工作区 ===== -->
        <Grid Grid.Row="0" Margin="12,12,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="236" MinWidth="200" MaxWidth="400" />
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- ========== 左侧：数据收发区 ========== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 接收区卡片 -->
                <Border Grid.Row="0" Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="接收区" Style="{DynamicResource CardHeaderStyle}" />
                        <Border Grid.Row="1" Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,10" />

                        <DockPanel Grid.Row="2">
                            <ListBox x:Name="lbSystemLog"
                                     DockPanel.Dock="Top"
                                     Height="36"
                                     MinHeight="18"
                                     MaxHeight="72"
                                     Background="{DynamicResource SecondaryHoverBgBrush}"
                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                     BorderThickness="3,1,1,1"
                                     FontFamily="Sarasa Mono SC, Consolas, Courier New"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextMutedBrush}"
                                     Padding="4,2"
                                     Margin="0,0,0,4"
                                     Visibility="Collapsed" />
                            <!-- 接收区：AvalonEdit（虚拟化渲染，拖窗口丝滑） -->
                            <avalonedit:TextEditor x:Name="editor"
                                FontFamily="Sarasa Mono SC, Consolas, Courier New"
                                FontSize="12"
                                ShowLineNumbers="True"
                                IsReadOnly="True"
                                WordWrap="False"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                Background="{DynamicResource ReceiveAreaBgBrush}"
                                Foreground="{DynamicResource LogReceivedBrush}"
                                BorderBrush="{DynamicResource InputBorderBrush}"
                                BorderThickness="1"
                                Padding="6,4"
                                SnapsToDevicePixels="True" />
                        </DockPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button x:Name="btnPauseDisplay"
                                    Content="暂停显示"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="btnPauseDisplay_Click"
                                    ToolTip="冻结接收区显示，串口后台照常接收（Ctrl+P）" />
                            <Button Content="导出日志"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Margin="0,0,8,0"
                                    Click="btnExportLog_Click"
                                    ToolTip="导出日志为 .txt 文件" />
                            <Button Content="清空接收区"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="btnClearReceive_Click"
                                    ToolTip="清空接收区（Ctrl+L）" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 发送区卡片 -->
                <Border Grid.Row="2" Style="{DynamicResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="发送区" Style="{DynamicResource CardHeaderStyle}" />
                        <Border Grid.Row="1" Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,10" />

                        <!-- 快捷发送按钮条 -->
                        <WrapPanel Grid.Row="2" x:Name="quickSendPanel"
                                   Margin="0,0,0,6"
                                   Visibility="Collapsed" />

                        <Grid Grid.Row="3">
                            <TextBox x:Name="tbSend"
                                     Style="{DynamicResource SendTextBoxStyle}"
                                     PreviewKeyDown="tbSend_PreviewKeyDown"
                                     TextChanged="tbSend_TextChanged" />
                            <TextBlock x:Name="tbSendPlaceholder"
                                       Text="输入要发送的内容…"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       FontFamily="Microsoft YaHei"
                                       FontSize="12"
                                       Padding="8,6,0,0"
                                       IsHitTestVisible="False" />
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <TextBlock Text="Enter 发送  ·  Shift+Enter 换行  ·  Ctrl+Enter 开关串口"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSubtleBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="清空发送区"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0"
                                        Click="btnClearSend_Click"
                                        ToolTip="清空发送区（Ctrl+Shift+L）" />
                                <Button Content="▾"
                                        x:Name="btnSendHistory"
                                        Width="26" Height="32"
                                        FontSize="10"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Click="btnSendHistory_Click"
                                        ToolTip="发送历史" />
                                <Button Content="发送"
                                        x:Name="btnSend"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="4,0,0,0"
                                        Click="btnSend_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== 右侧：参数配置区 ========== -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 串口配置卡片 -->
                    <Border Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="串口配置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="串口号" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbPortName"
                                          DropDownOpened="cbPortName_DropDownOpened" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="波特率" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbBaudRate" IsEditable="True" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="数据位" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cbDataBits" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="停止位" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cbStopBits" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="校验位" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cbParity" />

                                <!-- 高级串口控制 -->
                                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                        Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,4" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="流控" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cbFlowControl" />

                                <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                          x:Name="chkDtr"
                                          Content="DTR（数据终端就绪）"
                                          Checked="chkDtr_Changed"
                                          Unchecked="chkDtr_Changed" />

                                <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                                          x:Name="chkRts"
                                          Content="RTS（请求发送）"
                                          Checked="chkRts_Changed"
                                          Unchecked="chkRts_Changed" />

                                <Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                                        x:Name="btnOpen"
                                        Content="打开串口"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Height="32"
                                        Click="btnOpen_Click"
                                        ToolTip="打开/关闭串口（Ctrl+Enter）" />
                                <CheckBox Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                                          x:Name="chkAutoReconnect"
                                          Content="自动重连"
                                          Checked="chkAutoReconnect_Changed"
                                          Unchecked="chkAutoReconnect_Changed" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 接收设置卡片 -->
                    <Border Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="接收设置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="接收模式" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbReceiveMode"
                                          SelectionChanged="cbReceiveMode_SelectionChanged" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="文本编码" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbReceiveCoding"
                                          SelectionChanged="cbReceiveCoding_SelectionChanged" />
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="时间戳" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Column="1" x:Name="cbTimestampFormat"
                                          SelectionChanged="cbTimestampFormat_SelectionChanged" />
                            </Grid>

                            <CheckBox x:Name="chkShowEcho"
                                      Content="消息回显"
                                      IsChecked="True"
                                      Checked="chkShowEcho_Changed"
                                      Unchecked="chkShowEcho_Changed" />

                            <CheckBox x:Name="chkShowLineNumbers"
                                      Content="行号显示"
                                      IsChecked="True"
                                      Checked="chkShowLineNumbers_Changed"
                                      Unchecked="chkShowLineNumbers_Changed" />

                            <CheckBox x:Name="chkSeparateSystemLog"
                                      Content="系统消息独立显示"
                                      IsChecked="True"
                                      Checked="chkSeparateSystemLog_Changed"
                                      Unchecked="chkSeparateSystemLog_Changed" />

                            <CheckBox x:Name="chkPersistTraffic"
                                      Content="串口打开时不重置流量计数"
                                      Checked="chkPersistTraffic_Changed"
                                      Unchecked="chkPersistTraffic_Changed" />
                        </StackPanel>
                    </Border>

                    <!-- 发送设置卡片 -->
                    <Border Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="发送设置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32" />
                                    <RowDefinition Height="32" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="发送模式" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbSendMode"
                                          SelectionChanged="cbSendMode_SelectionChanged" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="文本编码" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbSendCoding"
                                          SelectionChanged="cbSendCoding_SelectionChanged" />
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="换行符" Style="{DynamicResource FormLabelStyle}" />
                                <ComboBox Grid.Column="1" x:Name="cbLineEnding" />
                            </Grid>

                            <CheckBox x:Name="chkAutoRepeat"
                                      Content="定时发送"
                                      Checked="chkAutoRepeat_Changed"
                                      Unchecked="chkAutoRepeat_Changed" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="间隔(ms)" Style="{DynamicResource FormLabelStyle}" />
                                <TextBox Grid.Column="1" x:Name="tbRepeatInterval"
                                         Height="28"
                                         FontFamily="Microsoft YaHei" FontSize="12"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         Background="{DynamicResource CardBgBrush}"
                                         BorderBrush="{DynamicResource InputBorderBrush}"
                                         BorderThickness="1" Padding="6,2"
                                         Text="1000"
                                         LostFocus="tbRepeatInterval_LostFocus" />
                            </Grid>

                            <CheckBox x:Name="chkAutoClear"
                                      Content="发送后清空发送区" />
                        </StackPanel>
                    </Border>

                    <!-- 外观卡片 -->
                    <Border Style="{DynamicResource CardBorderStyle}" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="外观" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12" />
                            <Button x:Name="btnThemeSwitch"
                                    Height="36"
                                    FontSize="13"
                                    Content="🌙 暗色模式"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="btnThemeSwitch_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ===== 状态栏 ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource StatusBarBgBrush}"
                Padding="16,4"
                SnapsToDevicePixels="True">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot"
                             Width="8" Height="8"
                             Fill="{DynamicResource StatusDotIdleBrush}"
                             Margin="0,0,6,0"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="tbStatusText"
                               Text="就绪"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="tbTraffic"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Visibility="Collapsed"
                               MouseRightButtonDown="tbTraffic_MouseRightButtonDown"
                               Cursor="Hand"
                               ToolTip="右键点击重置流量计数" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="tbPortInfo"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
