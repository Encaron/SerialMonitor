                                <CheckBox x:Name="chkFreqLines" Content="{DynamicResource 显示连线}" HorizontalAlignment="Left"
                                          Checked="chkFreqLines_Changed" Unchecked="chkFreqLines_Changed"/>
                                <CheckBox x:Name="chkFreqValueHud" Content="{DynamicResource 数值显示}" HorizontalAlignment="Left"
                                          Checked="chkFreqValueHud_Changed" Unchecked="chkFreqValueHud_Changed"/>
