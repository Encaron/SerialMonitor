                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 曲线详情（暂停后点击曲线） -->
                        <Grid x:Name="rightPlotDetail" Visibility="Collapsed" Margin="0,0,6,0">
