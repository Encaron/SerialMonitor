                                                Height="22" MinWidth="28" FontSize="9" Padding="4,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→无}"/>
                                        <Button Content="{DynamicResource 名字}" Tag="name" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="34" FontSize="9" Padding="4,0" Margin="2,0,0,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→文本模式，值为按键名}"/>
                                        <Button Content="up" Tag="up" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="26" FontSize="9" Padding="4,0" Margin="2,0,0,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→文本模式，值为 up}"/>
                                        <Button Content="down" Tag="down" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="32" FontSize="9" Padding="4,0" Margin="2,0,0,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→文本模式，值为 down}"/>
                                        <Button Content="on" Tag="on" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="24" FontSize="9" Padding="4,0" Margin="2,0,0,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→文本模式，值为 on}"/>
                                        <Button Content="off" Tag="off" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="24" FontSize="9" Padding="4,0" Margin="2,0,0,0"
                                                Click="ModulePressValue_Click" ToolTip="{DynamicResource 按下→文本模式，值为 off}"/>
                                    </WrapPanel>
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,6"/>
                                    <TextBlock Text="松开发送" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
