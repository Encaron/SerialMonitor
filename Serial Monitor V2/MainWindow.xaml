<Window x:Class="串口助手.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Serial Monitor"
        Width="960" Height="640"
        MinWidth="720" MinHeight="560"
        FontFamily="Microsoft YaHei"
        Closing="MainWindow_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontSize="12"
        Icon="Icons/icon.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ===== 调色板 ===== -->
        <SolidColorBrush x:Key="WindowBgBrush"      Color="#F0F0F0" />
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush"     Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#555555" />
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#999999" />
        <SolidColorBrush x:Key="PrimaryBrush"        Color="#0078D4" />
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#106EBE" />
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#005A9E" />
        <SolidColorBrush x:Key="SecondaryBrush"      Color="#888888" />
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#666666" />
        <SolidColorBrush x:Key="SuccessBrush"        Color="#10B981" />
        <SolidColorBrush x:Key="SuccessHoverBrush"   Color="#059669" />
        <SolidColorBrush x:Key="StatusBarBgBrush"    Color="#E6E6E6" />
        <SolidColorBrush x:Key="SeparatorBrush"      Color="#EEEEEE" />
        <SolidColorBrush x:Key="InputBorderBrush"    Color="#D0D0D0" />
        <SolidColorBrush x:Key="LogSystemBrush"  Color="#999999" />
        <SolidColorBrush x:Key="LogSentBrush"    Color="#0078D4" />
        <SolidColorBrush x:Key="LogReceivedBrush" Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextSubtleBrush"           Color="#BBBBBB" />
        <SolidColorBrush x:Key="TextFaintBrush"            Color="#CCCCCC" />
        <SolidColorBrush x:Key="SecondaryHoverBgBrush"     Color="#F5F5F5" />
        <SolidColorBrush x:Key="ButtonDisabledBgBrush"     Color="#E8E8E8" />
        <SolidColorBrush x:Key="ReceiveAreaBgBrush"        Color="#FAFAFA" />
        <SolidColorBrush x:Key="StatusDotIdleBrush"        Color="#CCCCCC" />
        <SolidColorBrush x:Key="HudBackgroundBrush"       Color="#F0FFFFFF" />
        <SolidColorBrush x:Key="HudBorderBrush"            Color="#33000000" />

        <!-- ===== CardBorderStyle ===== -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Opacity="0.10" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== CheckBox -> ToggleSwitch ===== -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Canvas Width="40" Height="22" ClipToBounds="True">
                                <Border x:Name="SwitchTrack" Width="40" Height="22"
                                        CornerRadius="11" Background="{DynamicResource InputBorderBrush}" />
                                <Ellipse x:Name="Knob" Width="18" Height="18" Fill="White"
                                         Canvas.Left="2" Canvas.Top="2" />
                            </Canvas>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                                              VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="Knob" Property="Canvas.Left" Value="20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 按键面板按钮模板（无悬停蒙层） ===== -->
        <ControlTemplate x:Key="KeyButtonTemplate" TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
            </Border>
        </ControlTemplate>

        <!-- ===== 彩色滑杆（轨道左半填充自定义颜色） ===== -->
        <Style x:Key="ColoredSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="sliderRoot" Height="28">
                            <!-- 轨道底色（全宽灰条，代码绘制风格） -->
                            <Border x:Name="trackBg" Height="4" CornerRadius="2" VerticalAlignment="Center"
                                    Background="{DynamicResource CardBorderBrush}"/>
                            <!-- 轨道图片（自定义图片风格，默认隐藏） -->
                            <Image x:Name="trackImage" Stretch="Fill"
                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                            <!-- 彩色填充（宽度+颜色由代码控制） -->
                            <Border x:Name="trackFill" Height="4" CornerRadius="2"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Width="0"/>
                            <!-- 透明轨道（覆盖在上面，接收鼠标交互） -->
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse x:Name="thumbDot"
                                                             Fill="{DynamicResource PrimaryBrush}"
                                                             Stroke="White" StrokeThickness="2"
                                                             Width="16" Height="16"/>
                                                    <Rectangle x:Name="thumbRect"
                                                               Fill="{DynamicResource PrimaryBrush}"
                                                               RadiusX="2" RadiusY="2"
                                                               Width="14" Height="14"
                                                               Visibility="Collapsed"/>
                                                    <Image x:Name="thumbImage"
                                                           Visibility="Collapsed"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Buttons ===== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" /><Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="16,0" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonDisabledBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" /><Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="14,0" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 视角切换按钮（#10 FFT）：介于 Primary 和 Secondary 之间 ===== -->
        <Style x:Key="PerspectiveToggleStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" /><Setter Property="Padding" Value="6,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Grid>
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,20,0" />
                                                <TextBlock Text="▾" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Center" Margin="8,0,20,0" Background="Transparent"
                                     BorderThickness="0" Foreground="{TemplateBinding Foreground}"
                                     FontSize="{TemplateBinding FontSize}" FontFamily="{TemplateBinding FontFamily}"
                                     CaretBrush="{TemplateBinding Foreground}" IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource CardBgBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            CornerRadius="3" Margin="0,1,0,0" SnapsToDevicePixels="True">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="False">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ContextMenu/MenuItem/ScrollViewer/ListBox ===== -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="ContextMenuMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="0" SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="3,1">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter x:Name="icon"
                                                  ContentSource="Icon" Margin="0,0,8,0"
                                                  VerticalAlignment="Center" SnapsToDevicePixels="True"
                                                  Width="16" Height="16"/>
                                <ContentPresenter x:Name="header"
                                                  ContentSource="Header" Margin="0,0,8,0"
                                                  VerticalAlignment="Center" SnapsToDevicePixels="True"
                                                  RecognizesAccessKey="True"/>
                                <TextBlock x:Name="shortcut"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="11" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="icon" Property="Width" Value="0"/>
                                <Setter TargetName="icon" Property="Margin" Value="0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ContextMenuSeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"
                                SnapsToDevicePixels="True"
                                Opacity="{TemplateBinding Opacity}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Thin ScrollBar（暗色/亮色自动跟随 DynamicResource） -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="{DynamicResource TextMutedBrush}"
                                                        CornerRadius="2" SnapsToDevicePixels="True"
                                                        Width="6" HorizontalAlignment="Right" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== QuickSend Chip ===== -->
        <Style x:Key="QuickSendChipStyle" TargetType="Button">
            <Setter Property="Height" Value="24" /><Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,0" /><Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" /><Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chip" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="{DynamicResource CardBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SendTextBox ===== -->
        <Style x:Key="SendTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Sarasa Mono SC, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" /><Setter Property="Padding" Value="6,4" />
            <Setter Property="AcceptsReturn" Value="True" /><Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="SpellCheck.IsEnabled" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="MinHeight" Value="68" /><Setter Property="MaxHeight" Value="140" />
        </Style>

        <!-- ===== 图标栏按钮样式 ===== -->
        <Style x:Key="IconBarButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="42" Height="42" Background="Transparent">
                            <Border x:Name="ActiveIndicator" Width="2" Height="24"
                                    Background="Transparent" CornerRadius="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ActiveIndicator" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 侧面板标题 ===== -->
        <Style x:Key="SidePanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== 按键面板发送模式下拉框 ===== -->
        <Style x:Key="KeyModeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                        <Setter Property="Padding" Value="8,4" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Border"
                                                Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Foreground="{TemplateBinding Foreground}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                ClickMode="Press" Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.5" HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" HorizontalAlignment="Left"
                                IsHitTestVisible="False" />
                            <Popup x:Name="Popup"
                                Placement="Bottom"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                AllowsTransparency="True"
                                Focusable="False"
                                PopupAnimation="Slide">
                                <Grid MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      MinWidth="{TemplateBinding ActualWidth}">
                                    <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource CardBgBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1" CornerRadius="4" Margin="0,2,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ================================================================ -->
    <!-- 主布局：3 Row（顶栏/内容/状态栏）                                -->
    <!-- ================================================================ -->
    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 顶栏 -->
        <Border Grid.Row="0" Background="{DynamicResource StatusBarBgBrush}" Padding="10,6">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="cbPortName" Width="90"
                              DropDownOpened="cbPortName_DropDownOpened" Margin="0,0,6,0" />
                    <ComboBox x:Name="cbBaudRate" Width="90" IsEditable="True" Margin="0,0,6,0" />
                    <Button x:Name="btnOpen" Content="{DynamicResource 打开串口}"
                            Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="76"
                            Click="btnOpen_Click" ToolTip="{DynamicResource 打开/关闭串口（Ctrl+Enter）}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 双语切换 -->
                    <Button x:Name="btnLangToggleTop" Height="32"
                            Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0"
                            Background="{DynamicResource StatusBarBgBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            Padding="8,0" Margin="0,0,12,0" Cursor="Hand"
                            Click="BtnLangToggleTop_Click" ToolTip="切换中/English">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="tbLangZh" Text="中" VerticalAlignment="Center"
                                       FontWeight="Bold" FontSize="14" />
                            <TextBlock x:Name="tbLangSlash" Text="/" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="2,0" />
                            <TextBlock x:Name="tbLangEn" Text="EN" VerticalAlignment="Center"
                                       FontWeight="Regular" FontSize="11" />
                        </StackPanel>
                    </Button>
                    <!-- 主题切换 -->
                    <Button x:Name="btnThemeToggleTop" Height="32"
                            Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0"
                            Background="{DynamicResource StatusBarBgBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            Padding="8,0" Margin="0,0,12,0" Cursor="Hand"
                            Click="BtnThemeToggleTop_Click" ToolTip="{DynamicResource 切换亮色/暗色主题}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="tbThemeToggleLabel" VerticalAlignment="Center" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Image x:Name="imgThemeToggle" Width="18" Height="18" Margin="5,0,0,0" />
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="tbStatusVersion" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 三列（图标栏 | 侧面板 | 主内容区） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42" />
                <ColumnDefinition x:Name="colSidePanel" Width="220" MinWidth="120" MaxWidth="520" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Col 0: 图标栏 -->
            <Border Grid.Column="0" Background="{DynamicResource StatusBarBgBrush}">
                <DockPanel LastChildFill="False">
                    <!-- 折叠按钮 -->
                    <Button x:Name="btnPanelCollapse" DockPanel.Dock="Top"
                            Content="◀" Width="24" Height="24" Padding="0"
                            Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0"
                            Margin="8,4,0,0" HorizontalAlignment="Center"
                            Click="BtnPanelCollapse_Click" ToolTip="{DynamicResource 折叠侧面板}" />
                    <RadioButton x:Name="tabSettings" DockPanel.Dock="Bottom"
                                 GroupName="IconBar" Style="{DynamicResource IconBarButtonStyle}"
                                 ToolTip="{DynamicResource 串口设置}" Margin="0,4" Checked="TabSettings_Checked">
                        <Rectangle Width="18" Height="18"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Icons/tabs/settings.png" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </RadioButton>
                    <!-- "+" 管理面板下拉（固定在设置上方） -->
                    <Button x:Name="btnAddPanel" DockPanel.Dock="Bottom"
                            Width="42" Height="42" Padding="0"
                            Foreground="{DynamicResource TextMutedBrush}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="20" FontWeight="Bold" Cursor="Hand"
                            Content="+" ToolTip="{DynamicResource 管理标签显示}" Margin="0,2"
                            Click="BtnAddPanel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Margin="0,4,0,0">
                        <RadioButton x:Name="tabReceive" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 接收区}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/receive.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabPlot" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 波形图}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/plot.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabKeys" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 按键面板}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/keys.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabSliders" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 滑杆面板}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/sliders.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabOLED" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource OLED}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/oled.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabJoystick" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 摇杆面板}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/joystick.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabSensors" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="{DynamicResource 传感面板}" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/tabs/sensors.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Col 2: GridSplitter -->
            <GridSplitter Grid.Column="2" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Col 1: 侧面板 -->
            <Border x:Name="sidePanelBorder" Grid.Column="1" Style="{DynamicResource CardBorderStyle}"
                    Margin="0,8,0,8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- 标题 -->
                    <TextBlock x:Name="tbSidePanelTitle" Grid.Row="0" Text="收发设置"
                               Style="{DynamicResource SidePanelTitleStyle}" Margin="0,0,0,10" />
                    <!-- 内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 接收区设置 -->
                        <ScrollViewer x:Name="rightReceive" VerticalScrollBarVisibility="Auto" Visibility="Visible"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="时间戳" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbTimestampFormat"
                                              SelectionChanged="cbTimestampFormat_SelectionChanged"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <CheckBox x:Name="chkShowEcho" Content="{DynamicResource 消息回显}" IsChecked="True"
                                          Checked="chkShowEcho_Changed" Unchecked="chkShowEcho_Changed"/>
                                <CheckBox x:Name="chkShowLineNumbers" Content="{DynamicResource 行号显示}" IsChecked="True"
                                          Checked="chkShowLineNumbers_Changed" Unchecked="chkShowLineNumbers_Changed"/>
                                <CheckBox x:Name="chkSeparateSystemLog" Content="{DynamicResource 系统消息独立显示}" IsChecked="True"
                                          Checked="chkSeparateSystemLog_Changed" Unchecked="chkSeparateSystemLog_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="换行符" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbLineEnding"/>
                                </Grid>
                                <CheckBox x:Name="chkAutoRepeat" Content="{DynamicResource 定时发送}"
                                          Checked="chkAutoRepeat_Changed" Unchecked="chkAutoRepeat_Changed"/>
                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="间隔(ms)" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Column="1" x:Name="tbRepeatInterval" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="1000"
                                             LostFocus="tbRepeatInterval_LostFocus"/>
                                </Grid>
                                <CheckBox x:Name="chkAutoClear" Content="{DynamicResource 发送后清空发送区}" Margin="0,8,0,0"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="接收模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbReceiveMode"
                                              SelectionChanged="cbReceiveMode_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="接收编码" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbReceiveCoding"
                                              SelectionChanged="cbReceiveCoding_SelectionChanged"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="发送模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbSendMode"
                                              SelectionChanged="cbSendMode_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="发送编码" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbSendCoding"
                                              SelectionChanged="cbSendCoding_SelectionChanged"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 绘图设置（Phase 3） -->
                        <ScrollViewer x:Name="rightPlot" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <!-- 显示模式 -->
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="显示模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbPlotMode" Height="28"
                                              FontFamily="Microsoft YaHei" FontSize="12"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource CardBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              SelectionChanged="cbPlotMode_Changed"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- X 轴：数据点数 -->
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="数据点数" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Column="1" x:Name="tbPlotXRange" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="200"
                                             LostFocus="tbPlotXRange_LostFocus"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- Y 轴 -->
                                <CheckBox x:Name="chkPlotYAuto" Content="{DynamicResource Y 轴自动}" HorizontalAlignment="Left"
                                          Checked="chkPlotYAuto_Changed" Unchecked="chkPlotYAuto_Changed"/>
                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最小值" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="tbPlotYMin" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="0"
                                             LostFocus="tbPlotYRange_LostFocus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最大值" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbPlotYMax" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="100"
                                             LostFocus="tbPlotYRange_LostFocus"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- 显示选项 -->
                                <CheckBox x:Name="chkPlotMarkers" Content="{DynamicResource 显示标点}" HorizontalAlignment="Left"
                                          Checked="chkPlotMarkers_Changed" Unchecked="chkPlotMarkers_Changed"/>
                                <CheckBox x:Name="chkPlotLines" Content="{DynamicResource 显示连线}" HorizontalAlignment="Left"
                                          Checked="chkPlotLines_Changed" Unchecked="chkPlotLines_Changed"/>
                                <CheckBox x:Name="chkPlotValueHud" Content="{DynamicResource 数值显示}" HorizontalAlignment="Left"
                                          Checked="chkPlotValueHud_Changed" Unchecked="chkPlotValueHud_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Button Content="{DynamicResource 🗑 清除全部曲线}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Margin="0,0,0,6" Click="btnPlotClear_Click"/>
                                <Button Content="{DynamicResource 📥 导出 CSV}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Click="btnPlotCsv_Click"/>
                                <!-- 操作提示 -->
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                           TextWrapping="Wrap" LineHeight="16">
                                    <Run Text="🖱 操作：" FontWeight="SemiBold"/>
                                    <Run Text="滚轮缩放"/>
                                    <Run Text=" · 右键拖拽平移"/>
                                    <Run Text=" · 悬停查看数值"/>
                                    <LineBreak/>
                                    <Run Text="📊 暂停后点上方「详细」按钮，选择曲线查看统计数据"/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 频域设置（#10 FFT） -->
                        <ScrollViewer x:Name="rightPlotFreq" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <!-- 数据源：从哪条 [plot,...] 曲线取数据做 FFT -->
                                <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                                        CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="数据源" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="cbFreqSource" Height="28"
                                              FontFamily="Microsoft YaHei" FontSize="12"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource CardBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              SelectionChanged="cbFreqSource_Changed"/>
                                    <Button Grid.Column="1" Content="↻" Width="24" Height="24" MinWidth="0"
                                            Margin="6,0,0,0" FontSize="12" Padding="2,0"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Click="btnFreqRefresh_Click" ToolTip="{DynamicResource 刷新数据源列表 + 重算频谱}"/>
                                    </Grid>
                                </StackPanel>
                                </Border>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- FFT 点数 -->
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FFT 点数" Style="{DynamicResource FormLabelStyle}"/>
