<Window x:Class="串口助手.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
        Title="Serial Monitor"
        Width="960" Height="640"
        MinWidth="720" MinHeight="560"
        FontFamily="Microsoft YaHei"
        Closing="MainWindow_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontSize="12"
        Icon="icon.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ===== 调色板 ===== -->
        <SolidColorBrush x:Key="WindowBgBrush"      Color="#F0F0F0" />
        <SolidColorBrush x:Key="CardBgBrush"         Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush"     Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextPrimaryBrush"    Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextSecondaryBrush"  Color="#555555" />
        <SolidColorBrush x:Key="TextMutedBrush"      Color="#999999" />
        <SolidColorBrush x:Key="PrimaryBrush"        Color="#0078D4" />
        <SolidColorBrush x:Key="PrimaryHoverBrush"   Color="#106EBE" />
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#005A9E" />
        <SolidColorBrush x:Key="SecondaryBrush"      Color="#888888" />
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#666666" />
        <SolidColorBrush x:Key="SuccessBrush"        Color="#10B981" />
        <SolidColorBrush x:Key="SuccessHoverBrush"   Color="#059669" />
        <SolidColorBrush x:Key="StatusBarBgBrush"    Color="#E6E6E6" />
        <SolidColorBrush x:Key="SeparatorBrush"      Color="#EEEEEE" />
        <SolidColorBrush x:Key="InputBorderBrush"    Color="#D0D0D0" />
        <SolidColorBrush x:Key="LogSystemBrush"  Color="#999999" />
        <SolidColorBrush x:Key="LogSentBrush"    Color="#0078D4" />
        <SolidColorBrush x:Key="LogReceivedBrush" Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextSubtleBrush"           Color="#BBBBBB" />
        <SolidColorBrush x:Key="TextFaintBrush"            Color="#CCCCCC" />
        <SolidColorBrush x:Key="SecondaryHoverBgBrush"     Color="#F5F5F5" />
        <SolidColorBrush x:Key="ButtonDisabledBgBrush"     Color="#E8E8E8" />
        <SolidColorBrush x:Key="ReceiveAreaBgBrush"        Color="#FAFAFA" />
        <SolidColorBrush x:Key="StatusDotIdleBrush"        Color="#CCCCCC" />

        <!-- ===== CardBorderStyle ===== -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Opacity="0.10" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ===== CheckBox -> ToggleSwitch ===== -->
        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Canvas Width="40" Height="22" ClipToBounds="True">
                                <Border x:Name="SwitchTrack" Width="40" Height="22"
                                        CornerRadius="11" Background="{DynamicResource InputBorderBrush}" />
                                <Ellipse x:Name="Knob" Width="18" Height="18" Fill="White"
                                         Canvas.Left="2" Canvas.Top="2" />
                            </Canvas>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                                              VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter TargetName="Knob" Property="Canvas.Left" Value="20" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Buttons ===== -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" /><Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="16,0" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonDisabledBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" /><Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="14,0" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="28" /><Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" /><Setter Property="Padding" Value="6,2" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2">
                                            <Grid>
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,20,0" />
                                                <TextBlock Text="▾" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" HorizontalContentAlignment="Left"
                                     VerticalContentAlignment="Center" Margin="8,0,20,0" Background="Transparent"
                                     BorderThickness="0" Foreground="{TemplateBinding Foreground}"
                                     FontSize="{TemplateBinding FontSize}" FontFamily="{TemplateBinding FontFamily}"
                                     CaretBrush="{TemplateBinding Foreground}" IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource CardBgBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            CornerRadius="3" Margin="0,1,0,0" SnapsToDevicePixels="True">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="False">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ContextMenu/MenuItem/ScrollViewer/ListBox ===== -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Thin ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== QuickSend Chip ===== -->
        <Style x:Key="QuickSendChipStyle" TargetType="Button">
            <Setter Property="Height" Value="24" /><Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,0" /><Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SecondaryHoverBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" /><Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="chip" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="Background" Value="{DynamicResource CardBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SendTextBox ===== -->
        <Style x:Key="SendTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Sarasa Mono SC, Consolas, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" /><Setter Property="Padding" Value="6,4" />
            <Setter Property="AcceptsReturn" Value="True" /><Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="SpellCheck.IsEnabled" Value="False" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="MinHeight" Value="68" /><Setter Property="MaxHeight" Value="140" />
        </Style>

        <!-- ===== 图标栏按钮样式 ===== -->
        <Style x:Key="IconBarButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Width="42" Height="42" Background="Transparent">
                            <Border x:Name="ActiveIndicator" Width="2" Height="24"
                                    Background="Transparent" CornerRadius="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ActiveIndicator" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 侧面板标题 ===== -->
        <Style x:Key="SidePanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <!-- ================================================================ -->
    <!-- 主布局：3 Row（顶栏/内容/状态栏）                                -->
    <!-- ================================================================ -->
    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: 顶栏 -->
        <Border Grid.Row="0" Background="{DynamicResource StatusBarBgBrush}" Padding="10,6">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="cbPortName" Width="90"
                              DropDownOpened="cbPortName_DropDownOpened" Margin="0,0,6,0" />
                    <ComboBox x:Name="cbBaudRate" Width="90" IsEditable="True" Margin="0,0,6,0" />
                    <Button x:Name="btnOpen" Content="打开串口"
                            Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="76"
                            Click="btnOpen_Click" ToolTip="打开/关闭串口（Ctrl+Enter）" />
                </StackPanel>
                <TextBlock Text="v2.0.0" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Row 1: 三列（图标栏 | 侧面板 | 主内容区） -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42" />
                <ColumnDefinition x:Name="colSidePanel" Width="220" MinWidth="120" MaxWidth="520" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Col 0: 图标栏 -->
            <Border Grid.Column="0" Background="{DynamicResource StatusBarBgBrush}">
                <DockPanel LastChildFill="False">
                    <!-- 折叠按钮 -->
                    <Button x:Name="btnPanelCollapse" DockPanel.Dock="Top"
                            Content="◀" Width="26" Height="26" Padding="0"
                            Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0"
                            Margin="8,4,0,0" HorizontalAlignment="Center"
                            Click="BtnPanelCollapse_Click" ToolTip="折叠侧面板" />
                    <RadioButton x:Name="tabSettings" DockPanel.Dock="Bottom"
                                 GroupName="IconBar" Style="{DynamicResource IconBarButtonStyle}"
                                 ToolTip="串口设置" Margin="0,4" Checked="TabSettings_Checked">
                        <Rectangle Width="18" Height="18"
                                   Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="Icons/settings.png" />
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </RadioButton>
                    <StackPanel Margin="0,4,0,0">
                        <RadioButton x:Name="tabReceive" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="接收区" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/receive.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabPlot" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="波形图" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/plot.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabKeys" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="按键面板" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/keys.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabSliders" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="滑杆面板" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/sliders.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                        <RadioButton x:Name="tabOLED" GroupName="IconBar"
                                     Style="{DynamicResource IconBarButtonStyle}"
                                     ToolTip="OLED" Checked="TabContent_Checked">
                            <Rectangle Width="18" Height="18"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource FindAncestor, AncestorType=RadioButton}}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="Icons/oled.png" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Col 2: GridSplitter -->
            <GridSplitter Grid.Column="2" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Col 1: 侧面板 -->
            <Border Grid.Column="1" Style="{DynamicResource CardBorderStyle}"
                    Margin="0,8,0,8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!-- 标题 -->
                    <TextBlock x:Name="tbSidePanelTitle" Grid.Row="0" Text="收发设置"
                               Style="{DynamicResource SidePanelTitleStyle}" Margin="0,0,0,10" />
                    <!-- 内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 接收区设置 -->
                        <ScrollViewer x:Name="rightReceive" VerticalScrollBarVisibility="Auto" Visibility="Visible"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="时间戳" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbTimestampFormat"
                                              SelectionChanged="cbTimestampFormat_SelectionChanged"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <CheckBox x:Name="chkShowEcho" Content="消息回显" IsChecked="True"
                                          Checked="chkShowEcho_Changed" Unchecked="chkShowEcho_Changed"/>
                                <CheckBox x:Name="chkShowLineNumbers" Content="行号显示" IsChecked="True"
                                          Checked="chkShowLineNumbers_Changed" Unchecked="chkShowLineNumbers_Changed"/>
                                <CheckBox x:Name="chkSeparateSystemLog" Content="系统消息独立显示" IsChecked="True"
                                          Checked="chkSeparateSystemLog_Changed" Unchecked="chkSeparateSystemLog_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="换行符" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbLineEnding"/>
                                </Grid>
                                <CheckBox x:Name="chkAutoRepeat" Content="定时发送"
                                          Checked="chkAutoRepeat_Changed" Unchecked="chkAutoRepeat_Changed"/>
                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="间隔(ms)" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Column="1" x:Name="tbRepeatInterval" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="1000"
                                             LostFocus="tbRepeatInterval_LostFocus"/>
                                </Grid>
                                <CheckBox x:Name="chkAutoClear" Content="发送后清空发送区" Margin="0,8,0,0"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="接收模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbReceiveMode"
                                              SelectionChanged="cbReceiveMode_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="接收编码" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbReceiveCoding"
                                              SelectionChanged="cbReceiveCoding_SelectionChanged"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="发送模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbSendMode"
                                              SelectionChanged="cbSendMode_SelectionChanged"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="发送编码" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbSendCoding"
                                              SelectionChanged="cbSendCoding_SelectionChanged"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 绘图设置（Phase 3） -->
                        <ScrollViewer x:Name="rightPlot" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <!-- 显示模式 -->
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="显示模式" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbPlotMode" Height="28"
                                              FontFamily="Microsoft YaHei" FontSize="12"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource CardBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              SelectionChanged="cbPlotMode_Changed"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- X 轴：数据点数 -->
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="数据点数" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Column="1" x:Name="tbPlotXRange" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="200"
                                             LostFocus="tbPlotXRange_LostFocus"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- Y 轴 -->
                                <CheckBox x:Name="chkPlotYAuto" Content="Y 轴自动" HorizontalAlignment="Left"
                                          Checked="chkPlotYAuto_Changed" Unchecked="chkPlotYAuto_Changed"/>
                                <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="最小值" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="tbPlotYMin" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="0"
                                             LostFocus="tbPlotYRange_LostFocus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最大值" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbPlotYMax" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="100"
                                             LostFocus="tbPlotYRange_LostFocus"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- 显示选项 -->
                                <CheckBox x:Name="chkPlotMarkers" Content="显示标点" HorizontalAlignment="Left"
                                          Checked="chkPlotMarkers_Changed" Unchecked="chkPlotMarkers_Changed"/>
                                <CheckBox x:Name="chkPlotLines" Content="显示连线" HorizontalAlignment="Left"
                                          Checked="chkPlotLines_Changed" Unchecked="chkPlotLines_Changed"/>
                                <CheckBox x:Name="chkPlotValueHud" Content="数值显示" HorizontalAlignment="Left"
                                          Checked="chkPlotValueHud_Changed" Unchecked="chkPlotValueHud_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Button Content="🗑 清除全部曲线" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Margin="0,0,0,6" Click="btnPlotClear_Click"/>
                                <Button Content="📥 导出 CSV" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Click="btnPlotCsv_Click"/>
                                <!-- 操作提示 -->
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                           TextWrapping="Wrap" LineHeight="16">
                                    <Run Text="🖱 操作：" FontWeight="SemiBold"/>
                                    <Run Text="滚轮缩放"/>
                                    <Run Text=" · 右键拖拽平移"/>
                                    <Run Text=" · 悬停查看数值"/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 按键设置（Phase 4） -->
                        <ScrollViewer x:Name="rightKeys" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <!-- 无按键选中时的提示 -->
                                <StackPanel x:Name="rightKeysNoSelection" Visibility="Visible">
                                    <TextBlock Text="按键属性" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap" LineHeight="18"
                                               Text="选择左侧按键以编辑属性。Ctrl+点击可多选。"/>
                                </StackPanel>
                                <!-- 多选状态 -->
                                <StackPanel x:Name="rightKeysMultiSelect" Visibility="Collapsed">
                                    <TextBlock Text="按键属性" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                    <TextBlock x:Name="tbKeysSelectedCount" FontSize="12"
                                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <!-- 多选：可批量修改的项 -->
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="发送模式" Style="{DynamicResource FormLabelStyle}"/>
                                        <ComboBox Grid.Column="1" x:Name="cbKeySendModeMulti" Height="28"
                                                  FontFamily="Microsoft YaHei" FontSize="12"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Background="{DynamicResource CardBgBrush}"
                                                  BorderBrush="{DynamicResource InputBorderBrush}"
                                                  SelectionChanged="cbKeySendModeMulti_Changed"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="发送值" Style="{DynamicResource FormLabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="tbKeySendValueMulti" Height="28"
                                                 FontFamily="Microsoft YaHei" FontSize="12"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource CardBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1" Padding="6,2"
                                                 LostFocus="tbKeySendValueMulti_LostFocus"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                    <TextBlock Text="颜色" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                    <WrapPanel x:Name="keysColorPanelMulti" Orientation="Horizontal"/>
                                </StackPanel>
                                <!-- 单选状态 -->
                                <StackPanel x:Name="rightKeysSingleSelect" Visibility="Collapsed">
                                    <TextBlock Text="按键属性" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="名字" Style="{DynamicResource FormLabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="tbKeyName" Height="28"
                                                 FontFamily="Microsoft YaHei" FontSize="12"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource CardBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1" Padding="6,2"
                                                 LostFocus="tbKeyName_LostFocus"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="发送模式" Style="{DynamicResource FormLabelStyle}"/>
                                        <ComboBox Grid.Column="1" x:Name="cbKeySendMode" Height="28"
                                                  FontFamily="Microsoft YaHei" FontSize="12"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Background="{DynamicResource CardBgBrush}"
                                                  BorderBrush="{DynamicResource InputBorderBrush}"
                                                  SelectionChanged="cbKeySendMode_Changed"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="发送值" Style="{DynamicResource FormLabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="tbKeySendValue" Height="28"
                                                 FontFamily="Microsoft YaHei" FontSize="12"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource CardBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1" Padding="6,2"
                                                 LostFocus="tbKeySendValue_LostFocus"/>
                                    </Grid>
                                    <CheckBox x:Name="chkKeyLocked" Content="锁定（只显示不收发）"
                                              HorizontalAlignment="Left" Margin="0,8,0,0"
                                              Checked="chkKeyLocked_Changed" Unchecked="chkKeyLocked_Changed"/>
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                    <TextBlock Text="外观" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,8"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="宽度" Style="{DynamicResource FormLabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="tbKeyWidth" Height="28"
                                                 FontFamily="Microsoft YaHei" FontSize="12"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource CardBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1" Padding="6,2" Text="80"
                                                 LostFocus="tbKeyWidth_LostFocus"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="高度" Style="{DynamicResource FormLabelStyle}"/>
                                        <TextBox Grid.Column="1" x:Name="tbKeyHeight" Height="28"
                                                 FontFamily="Microsoft YaHei" FontSize="12"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 Background="{DynamicResource CardBgBrush}"
                                                 BorderBrush="{DynamicResource InputBorderBrush}"
                                                 BorderThickness="1" Padding="6,2" Text="36"
                                                 LostFocus="tbKeyHeight_LostFocus"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                    <TextBlock Text="颜色" Style="{DynamicResource FormLabelStyle}" Margin="0,0,0,6"/>
                                    <WrapPanel x:Name="keysColorPanel" Orientation="Horizontal"/>
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                    <Button Content="🗑 删除此按键" Style="{DynamicResource SecondaryButtonStyle}"
                                            Height="28" Click="btnKeyDelete_Click" Foreground="#E74856"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 设置面板 -->
                        <ScrollViewer x:Name="rightSettings" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <TextBlock Text="串口配置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="数据位" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbDataBits"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="停止位" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbStopBits"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="校验位" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cbParity"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="流控" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cbFlowControl"/>
                                </Grid>
                                <CheckBox x:Name="chkDtr" Content="DTR（数据终端就绪）"
                                          Checked="chkDtr_Changed" Unchecked="chkDtr_Changed"/>
                                <CheckBox x:Name="chkRts" Content="RTS（请求发送）"
                                          Checked="chkRts_Changed" Unchecked="chkRts_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <CheckBox x:Name="chkAutoReconnect" Content="自动重连"
                                          Checked="chkAutoReconnect_Changed" Unchecked="chkAutoReconnect_Changed"/>
                                <CheckBox x:Name="chkPersistTraffic" Content="串口打开时不重置流量计数"
                                          Checked="chkPersistTraffic_Changed" Unchecked="chkPersistTraffic_Changed"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <TextBlock Text="外观" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                <Button x:Name="btnThemeSwitch" Height="36" FontSize="13"
                                        Content="🌙 暗色模式" Style="{DynamicResource SecondaryButtonStyle}"
                                        Click="btnThemeSwitch_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Col 3: 主内容区 -->
            <Grid Grid.Column="3" Margin="0,8,12,8">
                <!-- 接收区 -->
                <Grid x:Name="panelReceive" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnPauseDisplay" Content="⏸ 暂停"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Click="btnPauseDisplay_Click" ToolTip="冻结接收区（Ctrl+P）"/>
                            <Button Content="导出日志" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Margin="6,0,0,0"
                                    Click="btnExportLog_Click" ToolTip="导出日志"/>
                            <Button Content="清空接收区" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Margin="6,0,0,0"
                                    Click="btnClearReceive_Click" ToolTip="清空（Ctrl+L）"/>
                            <Button Content="🔍 搜索" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Margin="6,0,0,0"
                                    Click="btnSearch_Click" ToolTip="搜索（Ctrl+F）"/>
                        </StackPanel>
                    </Border>
                    <DockPanel Grid.Row="1">
                        <ListBox x:Name="lbSystemLog" DockPanel.Dock="Top"
                                 Height="36" MinHeight="18" MaxHeight="72"
                                 Background="{DynamicResource SecondaryHoverBgBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="3,1,1,1"
                                 FontFamily="Sarasa Mono SC, Consolas, Courier New" FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}" Padding="4,2"
                                 Margin="0,2,0,4" Visibility="Collapsed"/>
                        <avalonedit:TextEditor x:Name="editor"
                            FontFamily="Sarasa Mono SC, Consolas, Courier New" FontSize="12"
                            ShowLineNumbers="True" LineNumbersForeground="{DynamicResource TextMutedBrush}"
                            IsReadOnly="True" WordWrap="False"
                            HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                            Background="{DynamicResource ReceiveAreaBgBrush}"
                            Foreground="{DynamicResource LogReceivedBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                            Padding="6,4" SnapsToDevicePixels="True"/>
                    </DockPanel>
                    <WrapPanel Grid.Row="2" x:Name="quickSendPanel" Margin="0,6,0,4" Visibility="Collapsed"/>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBox x:Name="tbSend" Style="{DynamicResource SendTextBoxStyle}"
                                     PreviewKeyDown="tbSend_PreviewKeyDown" TextChanged="tbSend_TextChanged"/>
                            <TextBlock x:Name="tbSendPlaceholder" Text="输入要发送的内容…"
                                       Foreground="{DynamicResource TextSubtleBrush}" FontFamily="Microsoft YaHei"
                                       FontSize="12" Padding="8,6,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <TextBlock Text="Enter 发送  ·  Shift+Enter 换行  ·  Ctrl+Enter 开关串口"
                                       FontSize="10" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="清空发送区" Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0" Click="btnClearSend_Click" ToolTip="清空发送区"/>
                                <Button Content="▾" x:Name="btnSendHistory" Width="26" Height="32" FontSize="10"
                                        Style="{DynamicResource SecondaryButtonStyle}" Click="btnSendHistory_Click" ToolTip="发送历史"/>
                                <Button Content="发送" x:Name="btnSend" Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="4,0,0,0" Click="btnSend_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 绘图（Phase 3） -->
                <Grid x:Name="panelPlot" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <!-- 顶部工具栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnPlotPause" Content="⏸ 暂停" Width="84"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" Click="btnPlotPause_Click"/>
                            <Button x:Name="btnPlotClear" Content="🗑 清除"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotClear_Click"/>
                            <Button x:Name="btnPlotCsv" Content="📥 CSV"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotCsv_Click"/>
                            <Button x:Name="btnPlotFit" Content="🔍 适应"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotFit_Click"/>
                        </StackPanel>
                    </Border>
                    <!-- 波形图区域（PlotView 在 C# 中懒加载） -->
                    <Grid Grid.Row="1" x:Name="plotArea">
                        <Border x:Name="plotHud" Panel.ZIndex="1"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,12,0" Padding="10,8" CornerRadius="6"
                                Background="#99000000" BorderBrush="#33FFFFFF" BorderThickness="1"
                                IsHitTestVisible="False" Visibility="Collapsed">
                            <StackPanel x:Name="plotHudPanel"/>
                        </Border>
                        <TextBlock x:Name="plotEmptyHint" Panel.ZIndex="0"
                                   Text="等待串口数据…" FontSize="14"
                                   Foreground="{DynamicResource TextSubtleBrush}" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- 按键（Phase 4） -->
                <Grid x:Name="panelKeys" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <!-- 正常模式工具栏 -->
                    <Border x:Name="keysToolbarNormal" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Visible">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnKeysEdit" Content="编辑"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0"
                                    Click="btnKeysEdit_Click" ToolTip="进入编辑模式"/>
                            <TextBlock Text="  Shift 切换大小写" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                    <!-- 编辑模式工具栏 -->
                    <Border x:Name="keysToolbarEdit" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnKeysDone" Content="完成"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0"
                                    Click="btnKeysDone_Click" ToolTip="退出编辑模式"/>
                            <Button x:Name="btnKeysAdd" Content="+ 添加"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnKeysAdd_Click" ToolTip="添加一个按键"/>
                            <Button x:Name="btnKeysLayout" Content="⌨ 键盘布局"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnKeysLayout_Click" ToolTip="从键盘布局预设批量创建按键"/>
                        </StackPanel>
                    </Border>
                    <!-- 按键内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 空状态提示（正常模式，无按键） -->
                        <StackPanel x:Name="keysEmptyHintNormal" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Visible">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[编辑]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 开始添加按键" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 空状态提示（编辑模式，无按键） -->
                        <StackPanel x:Name="keysEmptyHintEdit" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[+ 添加]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 或 " FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                                <TextBlock Text="[⌨ 键盘布局]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 批量创建" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 按键按钮区域（WrapPanel 自动流式排列） -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <WrapPanel x:Name="keysPanel" Margin="8,8,0,8" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- 滑杆（Phase 4） -->
                <Grid x:Name="panelSliders" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <Button Content="编辑" Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"/>
                    </Border>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="[编辑]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text=" 开始添加滑杆" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- OLED（Phase 4） -->
                <Grid x:Name="panelOLED" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <Button Content="编辑" Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"/>
                    </Border>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="[编辑]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Text=" 开始添加 OLED" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- Row 2: 状态栏 -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBgBrush}" Padding="16,4">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot" Width="8" Height="8"
                             Fill="{DynamicResource StatusDotIdleBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbStatusText" Text="就绪" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbTraffic" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" Visibility="Collapsed"
                               MouseRightButtonDown="tbTraffic_MouseRightButtonDown" Cursor="Hand"
                               ToolTip="右键点击重置流量计数"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="tbPortInfo" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                    <TextBlock FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0" Text="v2.0.0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
