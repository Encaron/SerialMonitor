                                    <Run Text="侧栏显示卡片概览和快速跳转。"/>
                                    <LineBreak/>
                                    <Run Text="✏ 编辑模式：" FontWeight="SemiBold"/>
                                    <Run Text="侧栏变为行管理器——添加/删除/排序卡片和组。"/>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- OLED 设置（Phase 4） -->
                        <ScrollViewer x:Name="rightOLED" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <!-- 默认：画布设置 -->
                                <StackPanel x:Name="rightOLEDSettings" Visibility="Visible">
                                <TextBlock Text="OLED 设置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                <TextBlock Text="画布尺寸" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="宽度" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="tbOLEDWidth" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="480"
                                             LostFocus="tbOLEDSize_LostFocus"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text=" px" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="高度" Style="{DynamicResource FormLabelStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="tbOLEDHeight" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Text="200"
                                             LostFocus="tbOLEDSize_LostFocus"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text=" px" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="预设尺寸" Style="{DynamicResource FormLabelStyle}"/>
                                    <ComboBox Grid.Column="1" x:Name="cbOLEDPreset" Height="28"
                                              FontFamily="Microsoft YaHei" FontSize="12"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource CardBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              SelectionChanged="cbOLEDPreset_Changed"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <TextBlock Text="橡皮擦大小" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                                    <Slider x:Name="sliderEraserWidth" Grid.Column="0" Minimum="3" Maximum="20"
                                            Value="5" IsSnapToTickEnabled="True" TickFrequency="1"
                                            VerticalAlignment="Center"
                                            ValueChanged="sliderEraserWidth_Changed"/>
                                    <TextBlock x:Name="tbEraserWidthValue" Grid.Column="1" Text="5 px"
                                               FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <Button Content="{DynamicResource 🗑 清屏}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" Click="btnOLEDClear_Click"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" LineHeight="16">
                                    <Run Text="坐标轴：起/中/终点标有刻度数字"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="C 代码写法：" FontWeight="SemiBold"/>
                                    <LineBreak/>
                                    <Run Text="Serial_Printf(&amp;huart1,"/>
                                    <LineBreak/>
                                    <Run Text="  &quot;[display,0,0,\&quot;hello\&quot;,24]\r\n&quot;);"/>
                                    <LineBreak/>
                                    <Run Text="  &quot;[display,10,20,\&quot;ok\&quot;,16,#FF0000]\r\n&quot;);"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="⚠ 内层引号前加 \ 转义" Foreground="#E74856"/>
                                    <LineBreak/>
                                    <Run Text="末尾 #RRGGBB 可选，不写=白色"/>
                                    <LineBreak/>
                                    <Run Text="[display-clear] 清屏"/>
                                </TextBlock>
                                </StackPanel>
                                <!-- 文字编辑模式 -->
                                <StackPanel x:Name="rightOLEDTextEditor" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="文字编辑" Style="{DynamicResource CardHeaderStyle}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                        <Button Content="✕" Width="22" Height="22" HorizontalAlignment="Right"
                                                Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="0"
                                                Click="btnTextEditCancel_Click" ToolTip="{DynamicResource 取消编辑}"/>
                                    </Grid>
                                    <!-- 位置 -->
                                    <TextBlock Text="位置" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,3,0">
                                            <TextBlock Text="X" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2"/>
                                            <TextBox x:Name="tbTextEditX" Height="28"
                                                     FontFamily="Microsoft YaHei" FontSize="12"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     Background="{DynamicResource CardBgBrush}"
                                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                                     BorderThickness="1" Padding="6,2"
                                                     TextChanged="TextEditField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="3,0,0,0">
                                            <TextBlock Text="Y" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,2"/>
                                            <TextBox x:Name="tbTextEditY" Height="28"
                                                     FontFamily="Microsoft YaHei" FontSize="12"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     Background="{DynamicResource CardBgBrush}"
                                                     BorderBrush="{DynamicResource InputBorderBrush}"
                                                     BorderThickness="1" Padding="6,2"
                                                     TextChanged="TextEditField_Changed"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- 内容 -->
                                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="内容" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 📋 复制}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="22" MinWidth="0" Padding="6,0" FontSize="10"
                                                Click="btnCopyTextContent_Click" ToolTip="{DynamicResource 复制文字内容}"/>
                                    </Grid>
                                    <TextBox x:Name="tbTextEditContent" Height="28"
                                             FontFamily="Microsoft YaHei" FontSize="12"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             Background="{DynamicResource CardBgBrush}"
                                             BorderBrush="{DynamicResource InputBorderBrush}"
                                             BorderThickness="1" Padding="6,2" Margin="0,0,0,8"
                                             TextChanged="tbTextEditContent_Changed"/>
                                    <!-- 字号 -->
                                    <TextBlock Text="字号" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cbTextEditFontSize" Height="28" Margin="0,0,0,8"
                                              FontFamily="Microsoft YaHei" FontSize="12"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource CardBgBrush}"
                                              BorderBrush="{DynamicResource InputBorderBrush}"
                                              SelectionChanged="cbTextEditFontSize_Changed"/>
                                    <!-- 颜色 -->
                                    <TextBlock Text="颜色" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border x:Name="textEditColorSwatch" Grid.Column="0" Width="32" Height="28" CornerRadius="4"
                                                Background="#FFFFFF" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                                                MouseLeftButtonDown="textEditColorSwatch_Click" Cursor="Hand"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 选择颜色}" Height="28" MinWidth="0" Padding="8,0" Margin="4,0,0,0"
                                                Style="{DynamicResource SecondaryButtonStyle}" Click="textEditColorSwatch_Click"/>
                                    </Grid>
                                    <!-- 锁定按钮（编辑已有文字时也可见） -->
                                    <Button x:Name="btnTextLock" Content="{DynamicResource 🔓 锁定}" Style="{DynamicResource SecondaryButtonStyle}"
                                            Height="28" MinWidth="0" Padding="6,0" Click="btnTextLock_Click"
                                            ToolTip="{DynamicResource 锁定/解锁元素}" Margin="0,0,0,8"/>
                                    <!-- 确定/取消（仅新建文字时显示） -->
                                    <Grid x:Name="textEditConfirmRow"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{DynamicResource 确定}" Style="{DynamicResource PrimaryButtonStyle}"
                                                Height="28" Margin="0,0,4,0" Click="btnTextEditConfirm_Click"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 取消}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="28" Click="btnTextEditCancel_Click"/>
                                    </Grid>
                                </StackPanel>
                                <!-- 形状属性编辑模式 -->
                                <StackPanel x:Name="rightOLEDShapeEditor" Visibility="Collapsed">
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock x:Name="tbShapeEditTitle" Text="图形属性" Style="{DynamicResource CardHeaderStyle}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                        <Button Content="✕" Width="22" Height="22" HorizontalAlignment="Right"
                                                Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="0"
                                                Click="btnShapeEditCancel_Click" ToolTip="{DynamicResource 取消选中}"/>
                                    </Grid>
                                    <TextBlock x:Name="tbShapeEditType" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                               Text="类型: —" Margin="0,0,0,8"/>
                                    <!-- 动态字段容器（C# 按类型生成行） -->
                                    <StackPanel x:Name="shapeFieldsContainer"/>
                                    <!-- 类型专属扩展容器（圆角矩形半径等未来控件使用） -->
                                    <StackPanel x:Name="shapeExtrasContainer"/>
                                    <!-- 填充复选框 -->
                                    <CheckBox x:Name="cbShapeFill" Content="{DynamicResource 实心填充}" Margin="0,0,0,6"
                                              FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                              Click="ShapeField_Changed"/>
                                    <!-- 线宽（填充时隐藏） -->
                                    <StackPanel x:Name="shapeLineWidthPanel" Margin="0,0,0,6">
                                        <TextBlock Text="线宽" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="cbShapeLineWidth" Height="28"
                                                  FontFamily="Microsoft YaHei" FontSize="12"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                  Background="{DynamicResource CardBgBrush}"
                                                  BorderBrush="{DynamicResource InputBorderBrush}"
                                                  SelectionChanged="ShapeField_Changed"/>
                                    </StackPanel>
                                    <!-- 颜色 -->
                                    <TextBlock Text="颜色" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border x:Name="shapeEditColorSwatch" Grid.Column="0" Width="32" Height="28" CornerRadius="4"
                                                Background="#FFFFFF" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                                                MouseLeftButtonDown="shapeEditColorSwatch_Click" Cursor="Hand"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 选择颜色}" Height="28" MinWidth="0" Padding="8,0" Margin="4,0,0,0"
                                                Style="{DynamicResource SecondaryButtonStyle}" Click="shapeEditColorSwatch_Click"/>
                                    </Grid>
                                    <!-- Z-order -->
                                    <Grid Margin="0,6,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{DynamicResource ↑ 置顶}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="24" FontSize="11" Click="btnShapeBringToFront_Click" Margin="0,0,2,0"/>
                                        <Button Grid.Column="1" Content="{DynamicResource ↓ 置底}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="24" FontSize="11" Click="btnShapeSendToBack_Click" Margin="2,0,0,0"/>
                                    </Grid>
                                    <!-- 操作按钮 -->
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{DynamicResource 🗑 删除图形}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="28" Click="btnShapeDelete_Click" Foreground="#E53935" Margin="0,0,4,0"/>
                                        <Button x:Name="btnShapeLock" Grid.Column="1" Content="{DynamicResource 🔓 锁定}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="28" MinWidth="0" Padding="6,0" Click="btnShapeLock_Click" ToolTip="{DynamicResource 锁定/解锁元素}"/>
                                    </Grid>
                                </StackPanel>
                                <!-- 共享协议预览（选中任意控件时显示） -->
                                <StackPanel x:Name="sharedProtocolPreview" Visibility="Collapsed">
                                    <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                    <Grid Margin="0,0,0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="协议预览" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 📋 复制}" Style="{DynamicResource SecondaryButtonStyle}"
                                                Height="24" MinWidth="0" Padding="6,0" FontSize="11"
                                                Click="btnCopyProtocol_Click" ToolTip="{DynamicResource 复制协议到剪贴板}"/>
                                    </Grid>
                                    <Border Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="8,6">
                                        <TextBox x:Name="tbProtocolPreview" FontSize="12"
                                                 FontFamily="Consolas, Courier New" Foreground="{DynamicResource TextSecondaryBrush}"
                                                 Text="—" TextWrapping="Wrap"
                                                 Background="Transparent" BorderThickness="0" IsReadOnly="True"
                                                 IsReadOnlyCaretVisible="False" Padding="0"
                                                 VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                        <!-- 设置面板（导航） -->
                        <ScrollViewer x:Name="rightSettings" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                                      Padding="0,0,4,0">
                            <StackPanel VerticalAlignment="Top" Margin="0,0,2,0">
                                <TextBlock Text="设置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                                <Button x:Name="btnSettingsSerial" Content="{DynamicResource 📡 串口配置}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="36" Margin="0,0,0,4" Click="BtnSettingsSerial_Click"/>
                                <Button x:Name="btnSettingsShortcuts" Content="{DynamicResource ⌨ 快捷键提示}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="36" Margin="0,0,0,4" Click="BtnSettingsShortcuts_Click"/>
                                <Button x:Name="btnSettingsExamples" Content="{DynamicResource 📖 使用示例}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="36" Margin="0,0,0,4" Click="BtnSettingsExamples_Click"/>
                                <Button x:Name="btnSettingsAssets" Content="{DynamicResource 🎨 素材自定义}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="36" Margin="0,0,0,4" Click="BtnSettingsAssets_Click"/>
                                <Button x:Name="btnSettingsAbout" Content="{DynamicResource ℹ 关于}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="36" Margin="0,0,0,4" Click="BtnSettingsAbout_Click"/>
                                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                                <!-- 双语切换 -->
                                <Button x:Name="btnLangToggleSettings" Height="36"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="0,0,0,4"
                                        Click="BtnLangToggleSettings_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock x:Name="tbLangZhSettings" Text="中" VerticalAlignment="Center"
                                                   FontWeight="Bold" FontSize="14" />
                                        <TextBlock x:Name="tbLangSlashSettings" Text="/" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="2,0" />
                                        <TextBlock x:Name="tbLangEnSettings" Text="EN" VerticalAlignment="Center"
                                                   FontWeight="Regular" FontSize="11" />
                                    </StackPanel>
                                </Button>
                                <!-- 主题切换 -->
                                <Button x:Name="btnThemeSwitch" Height="36" FontSize="13"
                                        Content="{DynamicResource 🌙 暗色模式}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Click="btnThemeSwitch_Click"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Col 3: 主内容区 -->
            <Grid Grid.Column="3" Margin="0,8,12,8">
                <!-- 接收区 -->
                <Grid x:Name="panelReceive" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                            Padding="8,4">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button x:Name="btnFilterMenu" Content="{DynamicResource 📡 筛选 ▾}"
                                        Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                        Padding="8,0" Click="BtnFilterMenu_Click"
                                        ToolTip="{DynamicResource 筛选接收区显示内容}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnPauseDisplay" Content="{DynamicResource ⏸ 暂停}"
                                        Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                        Click="btnPauseDisplay_Click" ToolTip="{DynamicResource 冻结接收区（Ctrl+P）}"/>
                                <Button Content="{DynamicResource 导出日志}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" MinWidth="0" Margin="6,0,0,0"
                                        Click="btnExportLog_Click" ToolTip="{DynamicResource 导出日志}"/>
                                <Button Content="{DynamicResource 清空接收区}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" MinWidth="0" Margin="6,0,0,0"
                                        Click="btnClearReceive_Click" ToolTip="{DynamicResource 清空（Ctrl+L）}"/>
                                <Button Content="{DynamicResource 🔍 搜索}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="28" MinWidth="0" Margin="6,0,0,0"
                                        Click="btnSearch_Click" ToolTip="{DynamicResource 搜索（Ctrl+F）}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="lbSystemLog" Grid.Row="0"
                                 Height="36" MinHeight="18" MaxHeight="72"
                                 Background="{DynamicResource SecondaryHoverBgBrush}"
                                 BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="3,1,1,1"
                                 FontFamily="Sarasa Mono SC, Consolas, Courier New" FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}" Padding="4,2"
                                 Margin="0,2,0,4" Visibility="Collapsed"/>
                        <avalonedit:TextEditor x:Name="editor" Grid.Row="1"
                            FontFamily="Sarasa Mono SC, Consolas, Courier New" FontSize="12"
                            ShowLineNumbers="True" LineNumbersForeground="{DynamicResource TextMutedBrush}"
                            IsReadOnly="True" WordWrap="False"
                            HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                            Background="{DynamicResource ReceiveAreaBgBrush}"
                            Foreground="{DynamicResource LogReceivedBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                            Padding="6,4" SnapsToDevicePixels="True">
                            <avalonedit:TextEditor.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋 复制" Click="EditorContext_Copy_Click"
                                              InputGestureText="Ctrl+C"
                                              Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <MenuItem Header="📄 全选" Click="EditorContext_SelectAll_Click"
                                              InputGestureText="Ctrl+A"
                                              Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <Separator Style="{StaticResource ContextMenuSeparatorStyle}"/>
                                    <MenuItem Header="🗑 清空接收区" Click="EditorContext_Clear_Click"
                                              InputGestureText="Ctrl+L"
                                              Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                    <MenuItem Header="⏸ 暂停显示" x:Name="menuPauseDisplay"
                                              Click="EditorContext_Pause_Click"
                                              Style="{StaticResource ContextMenuMenuItemStyle}"/>
                                </ContextMenu>
                            </avalonedit:TextEditor.ContextMenu>
                        </avalonedit:TextEditor>
                        <Button x:Name="btnScrollToBottom" Grid.Row="1"
                                Content="{DynamicResource ↓ 回到底部}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Height="28" MinWidth="0" Padding="8,0" FontSize="11"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,8,8" Visibility="Collapsed"
                                Click="BtnScrollToBottom_Click"
                                ToolTip="{DynamicResource 回到底部}"/>
                    </Grid>
                    <WrapPanel Grid.Row="2" x:Name="quickSendPanel" Margin="0,6,0,4" Visibility="Collapsed"/>
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBox x:Name="tbSend" Style="{DynamicResource SendTextBoxStyle}"
                                     PreviewKeyDown="tbSend_PreviewKeyDown" TextChanged="tbSend_TextChanged"/>
                            <TextBlock x:Name="tbSendPlaceholder" Text="输入要发送的内容…"
                                       Foreground="{DynamicResource TextSubtleBrush}" FontFamily="Microsoft YaHei"
                                       FontSize="12" Padding="8,6,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <TextBlock Text="Enter 发送  ·  Shift+Enter 换行  ·  Ctrl+L 清空接收  ·  Ctrl+P 暂停  ·  Ctrl+Enter 开关串口"
                                       FontSize="10" Foreground="{DynamicResource TextSubtleBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="tbHexWarning" Foreground="#E8A838" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed"/>
                                <Button Content="{DynamicResource 清空发送区}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="0,0,8,0" Click="btnClearSend_Click" ToolTip="{DynamicResource 清空发送区}"/>
                                <Button Content="▾" x:Name="btnSendHistory" Width="26" Height="32" FontSize="10"
                                        Style="{DynamicResource SecondaryButtonStyle}" Click="btnSendHistory_Click" ToolTip="{DynamicResource 发送历史}"/>
                                <Button Content="{DynamicResource 发送}" x:Name="btnSend" Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="4,0,0,0" Click="btnSend_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 绘图（Phase 3）+ 调参工作台（#8） -->
                <Grid x:Name="panelPlot" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 0: 工具栏 -->
                        <RowDefinition Height="*"/>      <!-- 1: 波形图 -->
                        <RowDefinition Height="Auto"/>  <!-- 2: 调参切换条 -->
                        <RowDefinition Height="Auto"/>  <!-- 3: GridSplitter -->
                        <RowDefinition Height="Auto"/>  <!-- 4: 调参抽屉 -->
                    </Grid.RowDefinitions>
                    <!-- 顶部工具栏 -->
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <!-- #10 FFT 视角切换 -->
                            <Button x:Name="btnPerspectiveToggle" Content="{DynamicResource ⏱ 时域  →  频域 📶}"
                                    Style="{DynamicResource PerspectiveToggleStyle}" Height="28" Padding="12,0"
                                    Click="btnPerspectiveToggle_Click" ToolTip="{DynamicResource 切换时域/频域视角}"/>
                            <Border Width="1" Height="20" Background="{DynamicResource SeparatorBrush}" Margin="8,0,6,0"
                                    VerticalAlignment="Center"/>
                            <Button x:Name="btnPlotPause" Content="{DynamicResource ⏸ 暂停}" Width="84"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" Click="btnPlotPause_Click"/>
                            <Button x:Name="btnPlotClear" Content="{DynamicResource 🗑 清除}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotClear_Click"/>
                            <Button x:Name="btnPlotCsv" Content="📥 CSV"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotCsv_Click"/>
                            <Button x:Name="btnPlotFit" Content="{DynamicResource 🔍 适应}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0" Click="btnPlotFit_Click"/>
                            <Button x:Name="btnPlotDetail" Content="{DynamicResource 📊 详细}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Margin="6,0,0,0"
                                    Click="btnPlotDetail_Click" ToolTip="{DynamicResource 暂停后查看指定曲线的统计数据}"/>
                        </StackPanel>
                    </Border>
                    <!-- 波形图区域（PlotView 在 C# 中懒加载） -->
                    <Grid Grid.Row="1" x:Name="plotArea">
                        <Border x:Name="plotHud" Panel.ZIndex="1"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,12,0" Padding="10,8" CornerRadius="6"
                                Background="{DynamicResource HudBackgroundBrush}"
                                BorderBrush="{DynamicResource HudBorderBrush}" BorderThickness="1"
                                IsHitTestVisible="False" Visibility="Collapsed">
                            <StackPanel x:Name="plotHudPanel"/>
                        </Border>
                        <!-- #10 FFT 频域 HUD：仅显示数据源名 -->
                        <Border x:Name="freqHud" Panel.ZIndex="1"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,12,0" Padding="8,6" CornerRadius="6"
                                Background="{DynamicResource HudBackgroundBrush}"
                                BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"
                                IsHitTestVisible="False" Visibility="Collapsed">
                            <TextBlock x:Name="freqHudLabel" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="plotEmptyHint" Panel.ZIndex="0"
                                   Text="等待串口数据…" FontSize="14"
                                   Foreground="{DynamicResource TextSubtleBrush}" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- 串口断开波形冻结水印 -->
                        <Border x:Name="plotFrozenOverlay" Panel.ZIndex="2"
                                Background="#40FFFFFF" CornerRadius="4" Padding="16,8"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,16,16" Visibility="Collapsed" IsHitTestVisible="False">
                            <TextBlock Text="串口已断开 · 数据冻结" FontSize="13"
                                       Foreground="{DynamicResource TextSubtleBrush}" FontStyle="Italic"/>
                        </Border>
                    </Grid>
                    <!-- 调参切换条（#8）—— 不遮挡横轴，独立一行更显眼 -->
                    <Border Grid.Row="2" x:Name="barTuningToggle"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                            Height="28" Visibility="Collapsed">
                        <Button x:Name="btnTuningToggle"
                                Content="{DynamicResource ▲ 调参工作台}" Width="140" Height="24"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                FontSize="12"
                                HorizontalAlignment="Center"
                                Click="btnTuningToggle_Click"
                                ToolTip="{DynamicResource 展开/收起调参滑杆}"/>
                    </Border>
                    <!-- 调参抽屉分隔条（#8） -->
                    <GridSplitter Grid.Row="3" x:Name="splitterTuning"
                                  Height="4" Visibility="Collapsed"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource SeparatorBrush}"/>
                    <!-- 调参抽屉内容（#8） -->
                    <ScrollViewer Grid.Row="4" x:Name="panelTuningDrawer"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource CardBgBrush}"
                                  BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                                  Visibility="Collapsed">
                        <StackPanel x:Name="tuningSlidersPanel" Margin="12,8"/>
                    </ScrollViewer>
                </Grid>

                <!-- 按键（Phase 4） -->
                <Grid x:Name="panelKeys" Visibility="Collapsed"
                      PreviewKeyDown="KeysPanel_PreviewKeyDown" Focusable="True">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <!-- 正常模式工具栏 -->
                    <Border x:Name="keysToolbarNormal" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Visible">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnKeysEdit" Content="{DynamicResource 编辑}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0" Padding="6,0"
                                    Click="btnKeysEdit_Click" ToolTip="{DynamicResource 进入编辑模式}"/>
                            <TextBlock Text="  Shift 切换大小写" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                    <!-- 编辑模式工具栏 -->
                    <Border x:Name="keysToolbarEdit" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnKeysDone" Content="{DynamicResource 完成}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0" Padding="6,0"
                                    Click="btnKeysDone_Click" ToolTip="{DynamicResource 退出编辑模式}"/>
                            <Button x:Name="btnKeysAdd" Content="{DynamicResource + 添加}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnKeysAdd_Click" ToolTip="{DynamicResource 添加一个按键}"/>
                            <Button x:Name="btnKeysLayout" Content="{DynamicResource ⌨ 键盘布局}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnKeysLayout_Click" ToolTip="{DynamicResource 从键盘布局预设批量创建按键}"/>
                            <Button x:Name="btnKeysClearAll" Content="{DynamicResource 🗑 清空全部}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnKeysClearAll_Click" ToolTip="{DynamicResource 删除所有按键}"
                                    Foreground="#E74856"/>
                        </StackPanel>
                    </Border>
                    <!-- 按键内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 空状态提示（正常模式，无按键） -->
                        <StackPanel x:Name="keysEmptyHintNormal" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Visible">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[编辑]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 开始添加按键" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 空状态提示（编辑模式，无按键） -->
                        <StackPanel x:Name="keysEmptyHintEdit" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[+ 添加]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 或 " FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                                <TextBlock Text="[⌨ 键盘布局]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 批量创建" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 按键按钮区域（按行排列，键盘布局保持行列结构） -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="keysPanel" Margin="8,8,0,8" Orientation="Vertical"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- 滑杆（Phase 4） -->
                <Grid x:Name="panelSliders" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <!-- 正常模式工具栏 -->
                    <Border x:Name="slidersToolbarNormal" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Visible">
                        <Button x:Name="btnSlidersEdit" Content="{DynamicResource 编辑}"
                                Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0" Padding="6,0"
                                HorizontalAlignment="Left"
                                Click="btnSlidersEdit_Click"/>
                    </Border>
                    <!-- 编辑模式工具栏 -->
                    <Border x:Name="slidersToolbarEdit" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnSlidersDone" Content="{DynamicResource 完成}"
                                    Style="{DynamicResource PrimaryButtonStyle}" Height="28" MinWidth="0" Padding="6,0"
                                    Click="btnSlidersDone_Click"/>
                            <Button x:Name="btnSlidersAdd" Content="{DynamicResource + 添加}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnSlidersAdd_Click"/>
                            <Button x:Name="btnSlidersClearAll" Content="{DynamicResource 🗑 清空全部}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0"
                                    Margin="6,0,0,0" Click="btnSlidersClearAll_Click"
                                    Foreground="#E74856"/>
                        </StackPanel>
                    </Border>
                    <!-- 滑杆内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 空状态（正常模式，无滑杆） -->
                        <StackPanel x:Name="slidersEmptyHintNormal" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Visible">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[编辑]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 开始添加滑杆" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 空状态（编辑模式，无滑杆） -->
                        <StackPanel x:Name="slidersEmptyHintEdit" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="点击" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="[+ 添加]" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                                <TextBlock Text=" 创建滑杆控件" FontSize="14" FontStyle="Italic" Foreground="{DynamicResource TextSubtleBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- 滑杆列表 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="slidersPanel" Margin="8,8,0,8" Orientation="Vertical"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- OLED（Phase 4 + #6 + #7） -->
                <Grid x:Name="panelOLED" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <!-- 锁定 -->
                            <Button x:Name="btnLockCanvas" Content="🔒" Width="34" Height="34" ToolTip="{DynamicResource 解锁画布（默认锁定，只看不画）}"
                                    FontSize="18"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="1,0"
                                    Click="btnLockCanvas_Click"/>
                            <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="5,3"/>
                            <!-- 选择 -->
                            <Button x:Name="btnToolSelect" Content="↖" Width="24" Height="24" ToolTip="{DynamicResource 选择（点击选中/拖拽调整）}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolSelect_Click"/>
                            <!-- 绘图工具 -->
                            <Button x:Name="btnToolPencil" Content="✏" Width="24" Height="24" ToolTip="{DynamicResource 画笔}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolPencil_Click"/>
                            <Button x:Name="btnToolLine" Content="📏" Width="24" Height="24" ToolTip="{DynamicResource 直线}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolLine_Click"/>
                            <Button x:Name="btnToolRect" Content="▭▾" Width="42" Height="24" ToolTip="{DynamicResource 矩形 (左键选择，右键切换类型)}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolRect_Click">
                                <Button.ContextMenu>
                                    <ContextMenu Placement="Bottom">
                                        <MenuItem Header="▭ 矩形" Style="{StaticResource ContextMenuMenuItemStyle}" Click="SubToolRect_Click"/>
                                        <MenuItem Header="▢ 圆角矩形" Style="{StaticResource ContextMenuMenuItemStyle}" Click="SubToolRoundedRect_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="btnToolCircle" Content="◯▾" Width="42" Height="24" ToolTip="{DynamicResource 圆 (左键选择，右键切换类型)}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolCircle_Click">
                                <Button.ContextMenu>
                                    <ContextMenu Placement="Bottom">
                                        <MenuItem Header="◯ 圆" Style="{StaticResource ContextMenuMenuItemStyle}" Click="SubToolCircle_Click"/>
                                        <MenuItem Header="⬭ 椭圆" Style="{StaticResource ContextMenuMenuItemStyle}" Click="SubToolEllipse_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="btnToolTriangle" Content="△" Width="24" Height="24" ToolTip="{DynamicResource 三角形}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolTriangle_Click"/>
                            <Button x:Name="btnToolArc" Content="⌒" Width="24" Height="24" ToolTip="{DynamicResource 弧线}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolArc_Click"/>
                            <Button x:Name="btnToolText" Content="T" Width="24" Height="24" ToolTip="{DynamicResource 文字}"
                                    FontWeight="Bold"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolText_Click"/>
                            <!-- 橡皮擦 -->
                            <Button x:Name="btnToolEraser" Content="🧹" Width="24" Height="24" ToolTip="{DynamicResource 橡皮擦}"
                                    Style="{DynamicResource SecondaryButtonStyle}" MinWidth="0" Padding="2,0"
                                    Click="btnToolEraser_Click"/>
                            <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="5,3"/>
                            <!-- 发送 -->
                            <Button x:Name="btnSendCanvas" Content="{DynamicResource 发送}" Height="26" MinWidth="0" Padding="8,0"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="btnSendCanvas_Click" ToolTip="{DynamicResource 重发全部图形到串口}"/>
                            <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="5,3"/>
                            <!-- 清屏 -->
                            <Button x:Name="btnOLEDClear" Content="{DynamicResource 🗑 清屏}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="26" MinWidth="0" Padding="8,0"
                                    Click="btnOLEDClear_Click" ToolTip="{DynamicResource 清除 OLED 屏幕（display-clear）}"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1" Background="{DynamicResource WindowBgBrush}">
                        <!-- Viewbox 只缩放画布，轴标签在外面固定字号 -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- X 轴刻度（固定 9pt，填满 Viewbox 宽度） -->
                            <Grid x:Name="oledXAxis" Grid.Row="0" Grid.Column="1" Height="16" Margin="0,0,0,2"/>
                            <!-- Y 轴刻度（固定 9pt，填满 Viewbox 高度） -->
                            <Grid x:Name="oledYAxis" Grid.Row="1" Grid.Column="0" Width="34" Margin="0,0,2,0"/>
                            <!-- 画布 Viewbox（NearestNeighbor = 清晰像素） -->
                            <Viewbox Grid.Row="1" Grid.Column="1" Stretch="Uniform">
                                <Border x:Name="oledCanvasBorder" Background="#111111" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <Canvas x:Name="oledCanvas" Width="640" Height="320" ClipToBounds="True"
                                            Background="Transparent"
                                            TextOptions.TextRenderingMode="Aliased"/>
                                </Border>
                            </Viewbox>
                            <TextBlock x:Name="oledEmptyHint" Grid.Row="1" Grid.Column="1"
                                       Text="等待串口数据…" FontSize="12" FontStyle="Italic" Foreground="#444444"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 摇杆（Phase 4） -->
                <Grid x:Name="panelJoystick" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border x:Name="joystickToolbar" Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnJoystickCenter" Content="{DynamicResource ⟲ 回中}"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Padding="8,0"
                                    Click="btnJoystickCenter_Click" ToolTip="{DynamicResource 将所有摇杆归零}"/>
                            <TextBlock Text="底板" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="8,0,2,0"/>
                            <Button x:Name="btnJoystickPadStyle" Content="手柄风 ▾"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Padding="8,0"
                                    Click="btnJoystickPadStyle_Click"
                                    ToolTip="{DynamicResource 切换摇杆底板（大圆盘）风格}"/>
                            <TextBlock Text="拇指" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="6,0,2,0"/>
                            <Button x:Name="btnJoystickThumbStyle" Content="手柄风 ▾"
                                    Style="{DynamicResource SecondaryButtonStyle}" Height="28" MinWidth="0" Padding="8,0"
                                    Click="btnJoystickThumbStyle_Click"
                                    ToolTip="{DynamicResource 切换摇杆拇指（拖拽圆钮）风格}"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="joystickPanel" Margin="16,12,16,12" Orientation="Horizontal"
                                    HorizontalAlignment="Center"/>
                    </ScrollViewer>
                </Grid>
                <!-- 传感面板 -->
                <Grid x:Name="panelSensors" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 工具栏 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SecondaryHoverBgBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
                        <Button x:Name="btnSensorEdit" Content="{DynamicResource 编辑}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Height="28" MinWidth="0" Padding="10,0"
                                HorizontalAlignment="Left"
                                Click="BtnSensorEdit_Click" />
                    </Border>
                    <!-- 可滚动的组区域 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="sensorRowsPanel" Margin="12,10,12,10" />
                    </ScrollViewer>
                </Grid>
                <!-- 设置子页面 -->
                <Grid x:Name="panelSettings" Visibility="Collapsed">
                    <!-- 串口配置 -->
                    <ScrollViewer x:Name="settingsSerialPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="16,12">
                            <Button Content="{DynamicResource ← 返回}" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Padding="10,0" HorizontalAlignment="Left"
                                    Click="BtnSettingsBack_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="串口配置" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,12"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="56"/><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="32"/><RowDefinition Height="32"/><RowDefinition Height="32"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="数据位" Style="{DynamicResource FormLabelStyle}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cbDataBits"
                                          ToolTip="{DynamicResource 每个字节的数据位数。常用 8 位}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="停止位" Style="{DynamicResource FormLabelStyle}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbStopBits"
                                          ToolTip="{DynamicResource 每个字节后的停止位数。常用 1 位}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="校验位" Style="{DynamicResource FormLabelStyle}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cbParity"
                                          ToolTip="错误检测方式。None=不校验，Odd=奇校验，Even=偶校验"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="流控" Style="{DynamicResource FormLabelStyle}"/>
                                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="cbFlowControl"
                                          ToolTip="数据流控制。None=无，RTS=硬件流控，XOnXOff=软件流控"/>
                            </Grid>
                            <CheckBox x:Name="chkDtr" Content="{DynamicResource DTR（数据终端就绪）}" Margin="0,8,0,0"
                                      Checked="chkDtr_Changed" Unchecked="chkDtr_Changed"
                                      ToolTip="{DynamicResource 数据终端就绪信号。某些设备需拉高此信号才开始工作}"/>
                            <CheckBox x:Name="chkRts" Content="{DynamicResource RTS（请求发送）}"
                                      Checked="chkRts_Changed" Unchecked="chkRts_Changed"
                                      ToolTip="{DynamicResource 请求发送信号。用于硬件流控或唤醒目标设备}"/>
                            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,8"/>
                            <CheckBox x:Name="chkAutoReconnect" Content="{DynamicResource 自动重连}"
                                      Checked="chkAutoReconnect_Changed" Unchecked="chkAutoReconnect_Changed"
                                      ToolTip="{DynamicResource 串口意外断开后自动尝试重新连接}"/>
                            <CheckBox x:Name="chkPersistTraffic" Content="{DynamicResource 串口打开时不重置流量计数}"
                                      Checked="chkPersistTraffic_Changed" Unchecked="chkPersistTraffic_Changed"
                                      ToolTip="{DynamicResource 保持上次连接的收发字节计数，不清零}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- 快捷键提示 -->
                    <ScrollViewer x:Name="settingsShortcutsPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="16,12">
                            <Button Content="{DynamicResource ← 返回}" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Padding="10,0" HorizontalAlignment="Left"
                                    Click="BtnSettingsBack_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="快捷键提示" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,16"/>
                            <StackPanel x:Name="shortcutListPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- 使用示例 -->
                    <ScrollViewer x:Name="settingsExamplesPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="16,12">
                            <Button Content="{DynamicResource ← 返回}" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Padding="10,0" HorizontalAlignment="Left"
                                    Click="BtnSettingsBack_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="使用示例" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"
                                       TextWrapping="Wrap">
                                <Run Text="设备通过串口发送 "/><Run Text="[type,arg1,arg2,...]" FontFamily="Consolas"
                                    Foreground="{DynamicResource PrimaryBrush}"/><Run Text=" 格式的消息，"/>
                                <Run Text="工具自动解析并路由到对应面板。方括号 "/><Run Text="[ ]" FontFamily="Consolas"
                                    Foreground="{DynamicResource PrimaryBrush}"/>
                                <Run Text=" 包裹每条消息，参数用逗号分隔。含逗号的参数用双引号包裹。"/>
                            </TextBlock>
                            <StackPanel x:Name="examplesListPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- 素材自定义 -->
                    <ScrollViewer x:Name="settingsAssetsPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="16,12">
                            <Button Content="{DynamicResource ← 返回}" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Padding="10,0" HorizontalAlignment="Left"
                                    Click="BtnSettingsBack_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="素材自定义" Style="{DynamicResource CardHeaderStyle}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"
                                       TextWrapping="Wrap"
                                       Text="滑杆和摇杆支持自定义图片素材。将 PNG 放入素材文件夹，软件在下拉菜单中自动识别新风格。"/>
                            <!-- 路径 -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,12,0,4"
                                       Text="📂 素材文件夹"/>
                            <Grid Margin="0,0,0,8">
                                <Border Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock x:Name="tbAssetsPath" FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap"
                                                   ToolTip="{DynamicResource 点击复制路径}"/>
                                        <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"
                                                   Text="👆 点击上方蓝色路径即可复制，粘贴到文件管理器打开此文件夹"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                       Text="在此文件夹下创建 joystick/ 和 sliders/ 子目录，按下方命名规则放入 PNG 即可。"/>

                            <!-- 摇杆 -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,16,0,4"
                                       Text="🕹 摇杆 — 底板 &amp; 拇指"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Text="📍 操作：摇杆标签页 → 找到「⟲ 回中」按钮 → 旁边有「底板 ▾」和「拇指 ▾」两个下拉按钮 → 点开即见你的自定义风格。"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="10,10">
                                    <StackPanel>
                                        <TextBlock Text="pad_风格名.png" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="底板   140×140 px" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="10,10">
                                    <StackPanel>
                                        <TextBlock Text="thumb_风格名.png" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="拇指    32×32 px" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"
                                       Text="内置风格（手柄风 / 极简风 / 经典风）始终可用。同名 PNG 可覆盖内置的代码绘制。"/>

                            <!-- 滑杆 -->
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,12,0,4"
                                       Text="🎚 滑杆 — 轨道 &amp; 滑钮"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Text="📍 操作：滑杆标签页 → 点击 [编辑] → 右侧面板滚动到底部 → 点「轨道 ▾」或「拇指 ▾」下拉按钮选择风格。轨道和滑钮可以独立混搭。"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="10,10">
                                    <StackPanel>
                                        <TextBlock Text="track_风格名.png" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="轨道横条   ≥200×4~12 px" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource SecondaryHoverBgBrush}" CornerRadius="4" Padding="10,10">
                                    <StackPanel>
                                        <TextBlock Text="thumb_风格名.png" FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="拖拽滑钮   16~48 px 方形" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="内置风格（默认 / 极简）始终可用。删掉对应 PNG 文件后重启软件，菜单中自动消失。"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- 关于 -->
                    <ScrollViewer x:Name="settingsAboutPage" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="16,12">
                            <Button Content="{DynamicResource ← 返回}" Style="{DynamicResource SecondaryButtonStyle}"
                                    Height="28" MinWidth="0" Padding="10,0" HorizontalAlignment="Left"
                                    Click="BtnSettingsBack_Click" Margin="0,0,0,16"/>
                            <TextBlock Text="Serial Monitor" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <Border x:Name="bdAboutVersion" CornerRadius="8" Padding="0"
                                    HorizontalAlignment="Left" Margin="0,0,0,20"
                                    Background="Transparent" BorderThickness="0">
                                <TextBlock x:Name="tbAboutVersion" FontSize="13"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                            <!-- 制作 -->
                            <TextBlock Text="制作" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="冯毅力" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <!-- 技术栈 -->
                            <TextBlock Text="技术栈" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16">
                                <Run Text=".NET 8.0 · WPF"/><LineBreak/>
                                <Run Text="OxyPlot 2.2.0 · AvalonEdit 6.3.1"/><LineBreak/>
                                <Run Text="CommunityToolkit.Mvvm"/>
                            </TextBlock>
                            <!-- 运行时 -->
                            <TextBlock Text="运行时" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="tbAboutRuntime" FontSize="13"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <!-- GitHub -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="GitHub" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Width="50"/>
                                <Button Content="{DynamicResource 📋 复制}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="24" MinWidth="0" Padding="8,0" FontSize="11"
                                        Margin="8,0,0,0" Click="BtnCopyGitHub_Click"/>
                            </StackPanel>
                            <TextBox x:Name="tbAboutGitHub" IsReadOnly="True" BorderThickness="0"
                                     FontSize="12" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     Background="Transparent" Padding="0" Margin="0,0,0,12"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled"
                                     MinLines="1" Cursor="Arrow"/>

                            <!-- 数据路径 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="数据" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Width="50"/>
                                <Button Content="{DynamicResource 📋 复制}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="24" MinWidth="0" Padding="8,0" FontSize="11"
                                        Margin="8,0,0,0" Click="BtnCopyDataPath_Click"/>
                            </StackPanel>
                            <TextBox x:Name="tbAboutDataPath" IsReadOnly="True" BorderThickness="0"
                                     FontSize="12" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     Background="Transparent" Padding="0" Margin="0,0,0,16"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled"
                                     MinLines="3" Cursor="Arrow"/>

                            <!-- Issue 反馈 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="反馈" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Width="50"/>
                                <Button Content="{DynamicResource 📋 复制}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="24" MinWidth="0" Padding="8,0" FontSize="11"
                                        Margin="8,0,0,0" Click="BtnCopyIssues_Click"/>
                                <Button Content="{DynamicResource ↗ 打开}" Style="{DynamicResource SecondaryButtonStyle}"
                                        Height="24" MinWidth="0" Padding="8,0" FontSize="11"
                                        Margin="6,0,0,0" Click="BtnOpenIssues_Click"/>
                            </StackPanel>
                            <TextBox x:Name="tbAboutIssues" IsReadOnly="True" BorderThickness="0"
                                     FontSize="12" FontFamily="Consolas"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     Background="Transparent" Padding="0" Margin="0,0,0,8"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Disabled"
                                     MinLines="1" Cursor="Arrow"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Row 2: 状态栏 -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBgBrush}" Padding="16,4">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="statusDot" Width="8" Height="8"
                             Fill="{DynamicResource StatusDotIdleBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbStatusText" Text="就绪" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="tbTraffic" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,0,0" Visibility="Collapsed"
                               MouseRightButtonDown="tbTraffic_MouseRightButtonDown" Cursor="Hand"
                               ToolTip="{DynamicResource 右键点击重置流量计数}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="tbPortInfo" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                    <TextBlock x:Name="tbSettingsVersion" FontSize="10" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
